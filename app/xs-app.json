{
    "welcomeFile": "index.html",
    "authenticationMethod": "route",
    "sessionTimeout": 10,
    "routes": [
        {
            "source": "^/odata/(.*)$",
            "target": "/odata/$1",
            "destination": "srv-api",
            "authenticationType": "xsuaa",
            "csrfProtection": false
        },
        {
            "source": "^/user-api(.*)",
            "destination": "srv-api",
            "authenticationType": "xsuaa",
            "csrfProtection": false
        },
        {
            "source": "^(.*)$",
            "target": "$1",
            "localDir": "purchaseorder/webapp",
            "authenticationType": "xsuaa",
            "csrfProtection": false
        }
    ],
    "logout": {
        "logoutEndpoint": "/my/logout",
        "logoutPage": "www.example.com/logout.html"
    }
}