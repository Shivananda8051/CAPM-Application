{
  "name": "firstcapm",
  "version": "1.0.0",
  "description": "Welcome to your new CAP project.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9.9.1",
    "@sap/cds-odata-v2-adapter-proxy": "^1.9.21",
    "@sap/xssec": "^4",
    "passport": "^0.6.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4.0",
    "@sap/cds-dk": "^9",
    "sqlite3": "^6.0.1"
  },
  "sapux": [
    "app/purchaseorder"
  ],
  "cds": {
    "requires": {
      "db": "hana",
      "uaa": {
        "kind": "xsuaa"
      },
      "auth": {
        "[development]": {
          "strategy": "mocked",
          "users": {
            "shiva": {
              "roles": [
                "Viewer"
              ],
              "userAttributes": {
                "BankName": [
                  "SBI"
                ]
              }
            },
            "anushka": {
              "roles": [
                "Admin",
                "Viewer"
              ],
              "userAttributes": {
                "BankName": [
                  "$UNRESTRICTED"
                ]
              }
            }
          }
        },
        "[production]": {
          "strategy": "JWT"
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  }
}
