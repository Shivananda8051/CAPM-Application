{
  "xsappname": "FirstCAPM",
  "scopes": [
    {
      "name": "$XSAPPNAME.Viewer",
      "description": "Able to view data"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Able to edit data"
    }
  ],
  "attributes": [
    {
      "name": "BankName",
      "description": "Bank name for row level security",
      "valueType": "string"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "View employee data",
      "default-role-name": "Viewer",
      "scope-references": [
        "$XSAPPNAME.Viewer"
      ],
      "attribute-references": [
        "BankName"
      ]
    },
    {
      "name": "Admin",
      "description": "Edit employee data",
      "default-role-name": "Admin",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ]
    }
  ],
  "authorities": [
    "$ACCEPT_GRANTED_AUTHORITIES"
  ],
  "oauth2-configuration": {
    "token-validity": 900,
    "refresh-token-validity": 1800,
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/login/callback"
    ]
  },
  "xsenableasyncservice": true
}