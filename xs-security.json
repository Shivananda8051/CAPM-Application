{
  "xsappname": "FirstCAPM",
  "scopes": [
    {
      "name": "$XSAPPNAME.Viewer",
      "description": "Able to view data"
    },
    { 
      "name": "$XSAPPNAME.Admin",
      "description": "Able to edit data"
    }
  ], 
  "attributes": [
    {
      "name": "Bankname",
      "description": "bank name to allow role level security",
      "valueType": "string"
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "View all the employees",
      "default-role-name": "Viewer : autherized to read all the data",
      "scope-references": [
        "$XSAPPNAME.Viewer"
      ],
      "attribute-references": [
        {
          "name": "Bankname"
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Able to edit data",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ]
    }
  ],
  "authorities": [
    "$ACCEPT_GRANTED_AUTHORITIES"
  ],
  "oauth2-configuration": {
    "token-validity": 900,
    "refresh-token-validity": 1800,
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com"
    ],
    "autoapprove": "false"
  },
  "xsenableasyncservice": "true"
}